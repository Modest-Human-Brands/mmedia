{
  "name": "mmedia",
  "version": "0.1.5",
  "description": "An event-driven media processing and streaming service handling on-the-fly image optimization, background video/audio transcoding with adaptive bitrate, and live RTMP/SRT/WebRTC ingest to HLS pipeline",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Modest-Human-Brands/mmedia.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.11.0 || ^24.14.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepare": "husky || true",
    "dev": "sh -c \"iii-cli start -c iii-config.yaml & iii-cli console --enable-flow\"",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "build": "motia build",
    "start": "motia start",
    "clean": "rm -rf .motia dist",
    "docker:build": "docker build --build-arg VERSION=dev --build-arg BUILD_TIME=now -t mmedia:dev .",
    "docker:start": "docker run --detach --name mmedia-dev --env-file .env.prod -p 3500:3000 mmedia:dev"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "execa": "^9.6.1",
    "image-meta": "^0.2.2",
    "ipx": "^3.1.1",
    "livekit-server-sdk": "^2.15.2",
    "mime-types": "^3.0.2",
    "motia": "^1.0.4-rc.1",
    "ofetch": "^1.5.1",
    "unstorage": "^1.17.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dotenvx/dotenvx": "^1.61.0",
    "@types/bun": "^1.3.11",
    "@types/mime-types": "^3.0.1",
    "eslint": "^10.2.0",
    "eslint-config-unjs": "^0.6.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "protobufjs",
    "sharp"
  ]
}
